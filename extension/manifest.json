{
  "manifest_version": 3,
  "name": "Preread - Amazon書籍 × NotebookLM 自動ソース追加",
  "version": "0.1.1",
  "description": "Amazonの書籍ページを開いたとき、関連する要約・レビュー・YouTube解説動画をNotebookLMに自動追加します",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Preread"
  },

  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.co.jp/*",
        "https://www.amazon.com/*"
      ],
      "js": ["content_scripts/amazon.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://notebooklm.google.com/*"
      ],
      "js": [
        "content_scripts/notebooklm.js"
      ],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "clipboardWrite",
    "notifications"
  ],

  "host_permissions": [
    "https://www.amazon.co.jp/*",
    "https://www.amazon.com/*",
    "https://notebooklm.google.com/*",
    "https://www.googleapis.com/*",
    "https://serpapi.com/*",
    "https://api.tavily.com/*",
    "https://www.youtube.com/*"
  ],

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
